.set-cover-body {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.set-cover-definition {
  margin: 0 0 0.45em;
  font-size: 0.54em;
  color: #334155;
  text-align: center;
}

.set-cover-layout {
  display: grid;
  grid-template-columns: 1.25fr 0.95fr;
  gap: 0.75em;
  width: 100%;
  align-items: stretch;
}

.set-cover-figure-panel,
.set-cover-bilp-panel {
  position: relative;
  min-height: 500px;
  padding: 0.45em;
  border-radius: 24px;
  background: white;
  border: 1px solid rgba(15, 23, 42, 0.14);
  box-shadow: 0 14px 32px rgba(15, 23, 42, 0.08);
}

.set-cover-figure-panel {
  overflow: visible;
}

.set-cover-svg {
  width: 100%;
  height: 500px;
  overflow: visible;
}

.set-ellipse {
  stroke-width: 4;
  opacity: 0.28;
}

.set-s1 {
  fill: #3b82f6;
  stroke: #1d4ed8;
}

.set-s2 {
  fill: #ef4444;
  stroke: #b91c1c;
}

.set-s3 {
  fill: #22c55e;
  stroke: #15803d;
}

.set-s4 {
  fill: #f97316;
  stroke: #c2410c;
}

.set-ellipse.selected {
  opacity: 0.38;
  stroke-width: 6;
}

.set-label {
  font-size: 22px;
  font-weight: 700;
}

.set-label-s1 {
  fill: #1d4ed8;
}

.set-label-s2 {
  fill: #b91c1c;
}

.set-label-s3 {
  fill: #15803d;
}

.set-label-s4 {
  fill: #c2410c;
}

.element-hit {
  fill: transparent;
  cursor: help;
}

.element-node {
  fill: #f8fafc;
  stroke: #0f172a;
  stroke-width: 3;
}

.element-label {
  text-anchor: middle;
  font-size: 30px;
  font-weight: 700;
  fill: #0f172a;
  pointer-events: none;
}

.element-group:hover .element-node {
  fill: rgba(59, 130, 246, 0.18);
  stroke-width: 5;
}

.element-tooltip {
  opacity: 0;
  pointer-events: none;
  transition: opacity 140ms ease, transform 140ms ease;
}

.element-group:hover .element-tooltip {
  opacity: 1;
}

.element-tooltip rect {
  fill: #0f172a;
  filter: drop-shadow(0 10px 18px rgba(15, 23, 42, 0.24));
}

.element-tooltip text {
  text-anchor: middle;
  font-size: 24px;
  font-weight: 700;
  fill: white;
}

.set-cover-bilp-panel {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0.75em;
}

.set-cover-bilp-panel .katex-display {
  font-size: 0.78em;
}

.set-cover-bilp-panel p {
  margin-top: 0.8em;
  font-size: 0.47em;
  color: #475569;
  text-align: center;
}

.set-cover-solution {
  padding-top: 0.25em;
  border-top: 1px solid rgba(15, 23, 42, 0.12);
}
