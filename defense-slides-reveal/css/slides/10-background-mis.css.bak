.mis-example-body {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mis-definition {
  margin: 0 0 0.45em;
  font-size: 0.54em;
  color: #334155;
  text-align: center;
}

.mis-layout {
  display: grid;
  grid-template-columns: 1.25fr 0.95fr;
  gap: 0.75em;
  width: 100%;
  align-items: stretch;
}

.mis-graph-panel,
.mis-bilp-panel {
  position: relative;
  min-height: 520px;
  padding: 0.45em;
  border-radius: 24px;
  background: white;
  border: 1px solid rgba(15, 23, 42, 0.14);
  box-shadow: 0 14px 32px rgba(15, 23, 42, 0.08);
}

.mis-graph-panel {
  overflow: visible;
}

.mis-graph {
  width: 100%;
  height: 520px;
  overflow: visible;
}

.mis-edge {
  stroke: #64748b;
  stroke-width: 5.5;
  stroke-linecap: round;
}

.mis-edge-hit {
  stroke: transparent;
  stroke-width: 30;
  stroke-linecap: round;
  cursor: help;
}

.mis-edge-group:hover .mis-edge {
  stroke: #0f172a;
  stroke-width: 7;
}

.edge-tooltip {
  opacity: 0;
  pointer-events: none;
  transition: opacity 140ms ease, transform 140ms ease;
}

.mis-edge-group:hover .edge-tooltip {
  opacity: 1;
}

.edge-tooltip rect {
  fill: #0f172a;
  stroke: none;
  filter: drop-shadow(0 10px 18px rgba(15, 23, 42, 0.24));
}

.edge-tooltip text {
  text-anchor: middle;
  font-size: 24px;
  font-weight: 700;
  fill: white;
}

.mis-node circle {
  fill: #f8fafc;
  stroke: #1e293b;
  stroke-width: 3;
}

.mis-node.selected circle {
  fill: rgba(59, 130, 246, 0.22);
  stroke: #1d4ed8;
  stroke-width: 4;
}

.mis-node text {
  text-anchor: middle;
  font-size: 30px;
  font-weight: 700;
  fill: #0f172a;
  pointer-events: none;
}

.mis-bilp-panel {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0.75em;
}

.mis-bilp-panel .katex-display {
  font-size: 0.82em;
}

.mis-bilp-panel p {
  margin-top: 0.8em;
  font-size: 0.47em;
  color: #475569;
  text-align: center;
}

.mis-selected-set {
  padding-top: 0.25em;
  border-top: 1px solid rgba(15, 23, 42, 0.12);
}
