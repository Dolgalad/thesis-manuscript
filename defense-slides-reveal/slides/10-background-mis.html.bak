                    <text y="-10">x₁ + x₆ ≤ 1</text>
                  </g>
                </g>
      
                <g class="mis-edge-group">
                  <line class="mis-edge" x1="325" y1="345" x2="312" y2="470" />
                  <line class="mis-edge-hit" x1="325" y1="345" x2="312" y2="470" />
                  <g class="edge-tooltip" transform="translate(319 384)">
                    <rect x="-82" y="-36" width="164" height="42" rx="12" />
                    <text y="-10">x₁ + x₇ ≤ 1</text>
