      <section class="slide mis-example-slide"
               data-section="Background"
               data-title="BILP Example: Maximum Independent Set">
      
        <div class="slide-body mis-example-body">
      
          <p class="mis-definition">
            An <strong>independent set</strong> is a set of vertices with no edge between any selected pair.
          </p>
      
          <div class="mis-layout">
      
            <div class="mis-graph-panel">
      
              <svg class="mis-graph" viewBox="0 0 620 520" role="img"
                   aria-label="Example graph for maximum independent set">
      
                <!-- Edges: visible line + thick transparent hover line + SVG tooltip -->
      
                <g class="mis-edge-group">
                  <line class="mis-edge" x1="325" y1="345" x2="540" y2="255" />
                  <line class="mis-edge-hit" x1="325" y1="345" x2="540" y2="255" />
                  <g class="edge-tooltip" transform="translate(433 278)">
                    <rect x="-82" y="-36" width="164" height="42" rx="12" />
                    <text y="-10">x₁ + x₃ ≤ 1</text>
                  </g>
                </g>
      
                <g class="mis-edge-group">
                  <line class="mis-edge" x1="325" y1="345" x2="352" y2="212" />
                  <line class="mis-edge-hit" x1="325" y1="345" x2="352" y2="212" />
                  <g class="edge-tooltip" transform="translate(340 250)">
                    <rect x="-82" y="-36" width="164" height="42" rx="12" />
                    <text y="-10">x₁ + x₄ ≤ 1</text>
