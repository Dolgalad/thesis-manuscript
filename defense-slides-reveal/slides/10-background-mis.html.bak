                <!-- Nodes -->
      
                <g class="mis-node">
                  <circle cx="325" cy="345" r="34" />
                  <text x="325" y="356">1</text>
                </g>
      
                <g class="mis-node selected">
                  <circle cx="344" cy="50" r="34" />
                  <text x="344" y="61">2</text>
