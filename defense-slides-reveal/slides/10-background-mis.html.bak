                <g class="mis-node selected">
                  <circle cx="80" cy="416" r="34" />
                  <text x="80" y="427">6</text>
                </g>
      
                <g class="mis-node selected">
                  <circle cx="312" cy="470" r="34" />
                  <text x="312" y="481">7</text>
                </g>
      
                <g class="mis-node">
                  <circle cx="494" cy="372" r="34" />
                  <text x="494" y="383">8</text>
                </g>
      
              </svg>
      
            </div>
      
            <div class="mis-bilp-panel">
              \[
                \begin{aligned}
                \max_{x} \quad
                  & \sum_{i \in V} x_i \\
                \text{s.t.} \quad
                  & x_i + x_j \leq 1,
                  && \forall (i,j) \in E, \\
                  & x_i \in \{0,1\},
                  && \forall i \in V.
                \end{aligned}
              \]
      
              <p>
                \(x_i = 1\) means vertex \(i\) is selected.
              </p>
      
              <p class="mis-selected-set fragment">
                Example solution:
                \[
                  S = \{2,3,6,7\}
                \]
              </p>
            </div>
      
          </div>
      
        </div>
      </section>

