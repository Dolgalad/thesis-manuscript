  shorttitle = {Optimizing {{Solution-Samplers}} for {{Combinatorial Problems}}},
  author = {Caramanis, Constantine and Fotakis, Dimitris and Kalavasis, Alkis and Kontonis, Vasilis and Tzamos, Christos},
