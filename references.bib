@misc{sun_discrete_2023,
  title = {Discrete {{Langevin Sampler}} via {{Wasserstein Gradient Flow}}},
  author = {Sun, Haoran and Dai, Hanjun and Dai, Bo and Zhou, Haomin and Schuurmans, Dale},
  year = 2023,
  month = feb,
  number = {arXiv:2206.14897},
  eprint = {2206.14897},
  primaryclass = {cs},
  publisher = {arXiv},
  urldate = {2024-05-11},
  abstract = {It is known that gradient-based MCMC samplers for continuous spaces, such as Langevin Monte Carlo (LMC), can be derived as particle versions of a gradient flow that minimizes KL divergence on a Wasserstein manifold. The superior efficiency of such samplers has motivated several recent attempts to generalize LMC to discrete spaces. However, a fully principled extension of Langevin dynamics to discrete spaces has yet to be achieved, due to the lack of well-defined gradients in the sample space. In this work, we show how the Wasserstein gradient flow can be generalized naturally to discrete spaces. Given the proposed formulation, we demonstrate how a discrete analogue of Langevin dynamics can subsequently be developed. With this new understanding, we reveal how recent gradient-based samplers in discrete spaces can be obtained as special cases by choosing particular discretizations. More importantly, the framework also allows for the derivation of novel algorithms, one of which, \textbackslash textit\textbraceleft Discrete Langevin Monte Carlo\textbraceright{} (DLMC), is obtained by a factorized estimate of the transition matrix. The DLMC method admits a convenient parallel implementation and time-uniform sampling that achieves larger jump distances. We demonstrate the advantages of DLMC on various binary and categorical distributions.},
  archiveprefix = {arXiv},
  keywords = {Computer Science - Machine Learning},
  file = {/home/crazycat/Zotero/storage/S5JPA8YL/Sun et al. - 2023 - Discrete Langevin Sampler via Wasserstein Gradient.pdf;/home/crazycat/Zotero/storage/Q994S7IT/2206.html}
