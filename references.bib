@inproceedings{wang_native_2025,
  title = {Native {{Adaptive Solution Expansion}} for {{Diffusion-based Combinatorial Optimization}}},
  booktitle = {The {{Fourteenth International Conference}} on {{Learning Representations}}},
  author = {Wang, Yu and Li, Yang and Ma, Jiale and Yan, Junchi and Chang, Yi},
  year = 2025,
  month = oct,
  urldate = {2026-05-03},
  abstract = {One central challenge in Neural Combinatorial Optimization (NCO) is handling hard constraints efficiently. Beyond the two classic paradigms, i.e., Local Construction (LC), which sequentially builds feasible solutions but scales poorly, and Global Prediction (GP), which produces one-shot heatmaps yet struggles with constraint conflicts, the recently proposed Adaptive Expansion (AE) shares the advantages of both by progressively growing partial solutions with instance-wise global awareness. However, existing realizations bolt AE onto external GP predictors, so their solution quality is bounded by the backbone and their inference cost scales with repeated global calls. In this paper, we fundamentally rethink adaptive expansion and make it native to a generative model, acting as its intrinsic decoding principle rather than an external wrapper. We propose NEXCO, a CO-specific masked diffusion framework that turns adaptive expansion into the model's own iterative unmasking process. Specifically, it involves a solution-expansion training procedure with a time-agnostic GNN denoiser, which learns diffusion trajectories between fully masked solutions and ground-truth solutions. With the trained time-agnostic denoiser, we introduce a novel solution expansion scheme at the solving stage, enabling adaptive control over the intermediate solution states. It is achieved by constructing candidate sets according to confidence scores and applying feasibility projection to expand the solution while respecting constraints. In this way, ``adaptive" is not an afterthought but the decoding itself: intermediate diffusion states are meaningful partial solutions and progress is instance-adaptive rather than schedule-bound. Extensive experiments on representative CO problems show that NEXCO achieves approximately 50\textbackslash\% improvement in solution quality and up to \$4\textbackslash times\$ faster inference compared to prior state-of-the-art solvers.},
  langid = {english},
  file = {/home/crazycat/Zotero/storage/BRTXMJV2/Wang et al. - 2025 - Native Adaptive Solution Expansion for Diffusion-based Combinatorial Optimization.pdf}
}

